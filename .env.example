# Copy to `.env` for local dev (`.env` is gitignored). `cargo run -p app` loads it
# via dotenvy. In prod/CI there is no `.env`; set real environment variables instead.

APP__SERVER__PORT=8080
APP__SERVER__ENVIRONMENT=local

# Postgres the app connects to (auto-migrates on startup when AUTO_MIGRATE=true).
# docker-compose default is postgres:postgres; a local Postgres is often your OS user.
APP__DATABASE__URL=postgres://postgres:postgres@localhost:5432/app
APP__DATABASE__MAX_CONNECTIONS=5
APP__DATABASE__AUTO_MIGRATE=true

# JWT keys. Easiest for local dev: point at PEM FILES (no multi-line values needed).
# The repo's test fixtures are a valid RSA keypair — fine for local dev, NOT for prod.
APP__AUTH__JWT_PUBLIC_KEY_FILE=crates/domain-auth/tests/fixtures/test_pub.pem
APP__AUTH__JWT_PRIVATE_KEY_FILE=crates/domain-auth/tests/fixtures/test_priv.pem
# Alternatively, inline PEMs (dotenvy expands \n in double-quoted values):
# APP__AUTH__JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# APP__AUTH__JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

APP__AUTH__ACCESS_TOKEN_TTL_SECONDS=900
APP__AUTH__REFRESH_TOKEN_TTL_DAYS=7

# Emails that receive the `admin` scope at login (admin UI access). Comma-separated.
APP__AUTH__ADMIN_EMAILS=admin@example.com

# Only needed in dev when running the Vite dev server (:5173) against this API.
APP__CORS_ALLOWED_ORIGINS=http://localhost:5173
