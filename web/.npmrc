# openapi-typescript (dev-only, used by `make gen-api`) pins peer typescript ^5.x;
# this repo runs TS 6 and no openapi-typescript release accepts it yet. It works
# fine under TS 6 (gen-api verified), so accept the peer mismatch to let npm ci
# resolve. Revisit when openapi-typescript widens its typescript peer range.
legacy-peer-deps=true
